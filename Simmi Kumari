<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Group 15 - Mobile App Skeleton</title>
    <style>
        body { font-family: sans-serif; margin: 0; padding: 0; display: flex; flex-direction: column; height: 100vh; }
        header { background: #333; color: white; padding: 1rem; text-align: center; }
        main { flex: 1; padding: 20px; overflow-y: auto; background: #f4f4f4; }
        nav { background: #eee; display: flex; justify-content: space-around; padding: 10px; border-top: 1px solid #ccc; }
        .placeholder-card { background: white; border: 1px solid #ddd; padding: 15px; margin-bottom: 10px; border-radius: 8px; }
    </style>
</head>
<body>
    <header><h1>App Name</h1></header>

    <main id="content">
        <div class="placeholder-card">
            <h3>Database Item Placeholder</h3>
            <p>This will pull from int_schema.sql data.</p>
        </div>
        <button>Add New Entry</button>
    </main>

    <nav>
        <a href="#home">Home</a>
        <a href="#data">View Data</a>
        <a href="#profile">Profile</a>
    </nav>
</body>
</html>
